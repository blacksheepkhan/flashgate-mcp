{
  "schemaVersion": "1.0",
  "server": {
    "name": "flashgate",
    "transport": "stdio",
    "protocol": "MCP JSON-RPC",
    "rootConfiguration": {
      "environmentVariable": "MCP_ROOT",
      "pathMode": "relative tool paths below an absolute configured root",
      "required": true,
      "productionRootMustBeAbsolute": true,
      "developmentCurrentDirectory": {
        "rootValue": ".",
        "optInEnvironmentVariable": "MCP_ALLOW_CWD_ROOT",
        "requiredOptInValue": "true"
      },
      "codexReadOnlyExampleRequires": {
        "environmentVariable": "MCP_READ_ONLY",
        "value": "true"
      }
    }
  },
  "tools": [
    {
      "name": "list_directory",
      "title": "List Directory",
      "description": "Lists files and directories below the configured filesystem root.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Relative directory path below the configured filesystem root. Defaults to '.' when omitted."
          }
        }
      },
      "resultSchema": {
        "type": "object",
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "isDir": {
                  "type": "boolean"
                },
                "size": {
                  "type": "integer"
                }
              },
              "required": [
                "name",
                "isDir",
                "size"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "entries"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "read_file",
      "title": "Read File",
      "description": "Reads a text file below the configured filesystem root.",
      "inputSchema": {
        "type": "object",
        "required": [
          "path"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Relative file path below the configured filesystem root."
          },
          "maxBytes": {
            "type": "integer",
            "minimum": 1,
            "description": "Maximum number of bytes to read. Defaults to the configured maximum file size."
          }
        }
      },
      "resultSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          }
        },
        "required": [
          "content",
          "size"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "get_path_info",
      "title": "Get Path Info",
      "description": "Returns existence and metadata for a file or directory below the configured filesystem root.",
      "inputSchema": {
        "type": "object",
        "required": [
          "path"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Relative file or directory path below the configured filesystem root."
          }
        }
      },
      "resultSchema": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "exists": { "const": false }
            },
            "required": ["path", "exists"],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "exists": { "const": true },
              "name": { "type": "string" },
              "isDir": { "type": "boolean" },
              "size": { "type": "integer" }
            },
            "required": ["path", "exists", "name", "isDir", "size"],
            "additionalProperties": false
          }
        ]
      }
    },
    {
      "name": "write_file",
      "title": "Write File",
      "description": "Writes a text file below the configured filesystem root.",
      "inputSchema": {
        "type": "object",
        "required": [
          "path"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Relative file path below the configured filesystem root."
          },
          "content": {
            "type": "string",
            "description": "Text content to write. An empty string is allowed."
          },
          "overwrite": {
            "type": "boolean",
            "description": "Whether an existing file may be overwritten. Defaults to false."
          }
        }
      },
      "resultSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "written": {
            "type": "boolean"
          }
        },
        "required": [
          "path",
          "size",
          "written"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "create_directory",
      "title": "Create Directory",
      "description": "Creates a directory and any missing parents below the configured filesystem root.",
      "inputSchema": {
        "type": "object",
        "required": [
          "path"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Relative directory path below the configured filesystem root."
          }
        }
      },
      "resultSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "created": {
            "type": "boolean"
          }
        },
        "required": [
          "path",
          "created"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "delete_path",
      "title": "Delete Path",
      "description": "Deletes a file or directory below the configured filesystem root.",
      "inputSchema": {
        "type": "object",
        "required": [
          "path"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Relative file or directory path below the configured filesystem root."
          },
          "recursive": {
            "type": "boolean",
            "description": "Whether a non-empty directory may be deleted recursively. Defaults to false."
          }
        }
      },
      "resultSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "deleted": {
            "type": "boolean"
          }
        },
        "required": [
          "path",
          "deleted"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "copy_path",
      "title": "Copy Path",
      "description": "Copies a file below the configured filesystem root. Directory copy is not supported.",
      "inputSchema": {
        "type": "object",
        "required": [
          "source",
          "target"
        ],
        "additionalProperties": false,
        "properties": {
          "source": {
            "type": "string",
            "minLength": 1,
            "description": "Relative source file path below the configured filesystem root."
          },
          "target": {
            "type": "string",
            "minLength": 1,
            "description": "Relative target file path below the configured filesystem root."
          },
          "overwrite": {
            "type": "boolean",
            "description": "Whether an existing target may be overwritten. Defaults to false."
          }
        }
      },
      "resultSchema": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "copied": {
            "type": "boolean"
          }
        },
        "required": [
          "source",
          "target",
          "copied"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "move_path",
      "title": "Move Path",
      "description": "Moves or renames a file or directory on the same volume below the configured filesystem root.",
      "inputSchema": {
        "type": "object",
        "required": [
          "source",
          "target"
        ],
        "additionalProperties": false,
        "properties": {
          "source": {
            "type": "string",
            "minLength": 1,
            "description": "Relative source file or directory path below the configured filesystem root."
          },
          "target": {
            "type": "string",
            "minLength": 1,
            "description": "Relative target file or directory path below the configured filesystem root."
          },
          "overwrite": {
            "type": "boolean",
            "description": "Whether an existing target may be overwritten. Defaults to false."
          }
        }
      },
      "resultSchema": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "moved": {
            "type": "boolean"
          }
        },
        "required": [
          "source",
          "target",
          "moved"
        ],
        "additionalProperties": false
      }
    }
  ],
  "commonErrors": [
    {
      "code": -32602,
      "name": "Invalid params",
      "description": "Malformed arguments, missing required arguments, invalid paths, or invalid filesystem operations."
    }
  ]
}
